TZ=America/Edmonton
PUID=1000
PGID=1000

MEDIA_ROOT=/mnt/storage/media
JELLYFIN_CONFIG_ROOT=/mnt/storage/jellyfin

IMMICH_VERSION=v2
UPLOAD_LOCATION=/mnt/storage/immich/upload
DB_DATA_LOCATION=/mnt/storage/immich/postgres
IMMICH_MODEL_CACHE_LOCATION=/mnt/storage/immich/model-cache
DB_STORAGE_TYPE=HDD

# Replace this in the real .env file. Automation generates a host-local value.
DB_PASSWORD=replace-with-generated-password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_HOSTNAME=immich-database
REDIS_HOSTNAME=immich-redis
